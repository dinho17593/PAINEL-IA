{
  "name": "zappbot-shopp",
  "version": "3.0.0",
  "description": "Automação WhatsApp com Gemini e Painel de Controle",
  "main": "server.js",
  "scripts": {
    "start": "node --expose-gc server.js",
    "dev": "nodemon --expose-gc server.js",
    "pm2": "pm2 start server.js --name zappbot --node-args=\"--expose-gc\"",
    "pm2:stop": "pm2 stop zappbot",
    "pm2:restart": "pm2 restart zappbot",
    "pm2:logs": "pm2 logs zappbot",
    "pm2:monit": "pm2 monit",
    "backup": "node scripts/backup.js",
    "backup:auto": "node scripts/backup.js --auto",
    "clean:sessions": "node scripts/clean-sessions.js",
    "update": "npm install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.13.3",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "google-tts-api": "^2.0.2",
    "https-proxy-agent": "^7.0.6",
    "mercadopago": "^2.0.11",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.2",
    "pino": "^9.1.0",
    "qrcode": "^1.5.4",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "bot",
    "automation",
    "gemini",
    "ai",
    "mercadopago"
  ],
  "author": "ZappBot Team",
  "license": "ISC"
}

